// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(200)
  lastname   String   @db.VarChar(300)
  username   String   @unique @db.VarChar(100)
  password   String   @db.LongText
  hash       String?  @db.LongText
  role       String   @default("user") @db.VarChar(50)
  created_at DateTime @default(now())
  task       Task[]
  logs       Logs[]
}

model Task {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(250)
  description String   @db.VarChar(200)
  priority    Boolean
  created_at  DateTime @default(now())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id]) //se necesita declarar la relacion que tendra si sera de 1 a muchos o muchos a muchos
}

model Logs {
  id         Int      @id @default(autoincrement())
  statusCode Int
  timestamp  DateTime
  path       String   @db.MediumText()
  error      String   @db.MediumText()
  errorCode  String   @db.MediumText()
  session_id Int?

  user User? @relation(fields: [session_id], references: [id])
}
